{
  "name": "tide-ide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @tide/desktop dev",
    "build": "pnpm --filter @tide/shared build && pnpm --filter @tide/desktop build",
    "build:shared": "pnpm --filter @tide/shared build",
    "tauri": "pnpm --filter @tide/desktop tauri",
    "tauri:dev": "pnpm --filter @tide/desktop tauri dev",
    "test": "pnpm --filter @tide/desktop test"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "better-sqlite3": "^11.0.0",
    "typebox": "^1.1.24"
  }
}
