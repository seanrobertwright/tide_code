{
  "identifier": "default",
  "description": "Default capabilities for Tide",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "core:window:allow-start-dragging",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
