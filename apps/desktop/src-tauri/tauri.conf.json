{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui-compat/main/tauri-conf.schema.json",
  "productName": "Tide",
  "version": "0.1.0",
  "identifier": "dev.tide.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "lsof -ti:5173 | xargs kill -9 2>/dev/null; pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "Tide",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#13141c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
