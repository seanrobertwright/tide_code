{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui-compat/main/tauri-conf.schema.json",
  "productName": "Tide",
  "version": "0.1.0",
  "identifier": "dev.tide.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "Tide",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#13141c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/pi-sidecar"
    ],
    "resources": [
      "resources/pi-extensions/*",
      "resources/pi-assets/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": null,
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      },
      "wix": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyQURBQUU0NUE1QzZERUUKUldUdWJWeGE1S3F0UXVHQ0g0VDZxTTVXZzN1OXl2eGs2b3V4YzQwS3dLNHkvSlRCNzFtbGtYbEEK",
      "endpoints": [
        "https://github.com/seanrobertwright/tide_code/releases/latest/download/latest.json"
      ]
    }
  }
}
