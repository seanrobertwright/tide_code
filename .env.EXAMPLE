# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: Web search (used by tide-web-search extension)
TAVILY_API_KEY=

# Updater endpoint (used at build time via TAURI_CONFIG override)
# Set this to your hosted latest.json URL for auto-update support
TIDE_UPDATER_URL=
